# cascade-img bridge configuration.
# Copy this file to a `.env` in the directory where you'll launch
# `cascade-mj-bridge`, then fill in the values below. It's loaded via
# python-dotenv at daemon startup. RUNBOOK.md is the step-by-step capture guide.

# --- Required (the daemon won't start without these) ---

# Discord user-account token — the one secret; treat it like a password.
# Captured from the Discord desktop app's DevTools Console; see RUNBOOK.md,
# section "DISCORD_USER_TOKEN — the credential", for the capture snippet.
DISCORD_USER_TOKEN=

# Channel ID of the Midjourney channel the bridge watches. Enable Developer Mode
# (Discord Settings -> Advanced), then right-click the channel -> Copy Channel ID.
MJ_CHANNEL_ID=

# /imagine slash-command version. DevTools -> Network: fire /imagine once, open
# the POST /api/v9/interactions request, copy data.version. Re-capture whenever
# Midjourney ships a new slash command (the bridge surfaces this as
# DISCORD_400_OUTDATED).
MJ_IMAGINE_VERSION=

# --- Conditionally required ---

# Server (guild) ID — needed whenever the MJ channel lives in a Discord server,
# which in practice is almost always. Right-click the server icon -> Copy Server
# ID. Config validation passes without it, but a guild-bound channel then fails
# the first /imagine with 400 Unknown Channel.
MJ_GUILD_ID=

# --- Optional (sensible defaults shown; uncomment only to override) ---

# /imagine slash-command application ID. The default is usually stable; only set
# it if interactions start returning 404.
#MJ_IMAGINE_COMMAND_ID=938956540159881230

# Where finished artifacts land (resolved relative to the bridge's cwd).
#MJ_OUTPUT_DIR=./generated

# HTTP port the bridge's Flask app listens on; the CLI and MCP server hit this.
#PORT=5000

# Bridge URL the CLI and MCP server connect to.
#CASCADE_BRIDGE_URL=http://127.0.0.1:5000

# Append-only prompt-log path (the agent's working memory).
#CASCADE_PROMPT_LOG=./cascade-prompt-log.jsonl

# Explicit path to this .env, overriding the cwd search — for launchd / systemd /
# Docker, where the working directory isn't this file's directory.
#CASCADE_DOTENV=/abs/path/to/.env

# SQLite job-store path (restart recovery for in-flight jobs).
#CASCADE_JOB_DB=<MJ_OUTPUT_DIR>/cascade-jobs.db
