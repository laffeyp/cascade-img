# cascade-img bridge configuration.
# Copy this file to a `.env` in the working directory where you'll launch
# `cascade-mj-bridge`, then fill in the values. The `.env` file is loaded
# via python-dotenv at daemon startup.

# Discord user-account token. Captured via DevTools in the Discord desktop
# app; see RUNBOOK / OPERATIONS for the procedure.
DISCORD_USER_TOKEN=
# Required before the bridge can start. Obtain it with the DevTools capture
# procedure documented step-by-step in RUNBOOK.md (credential capture section).
# Channel ID of the Midjourney channel the bridge will watch.
# Enable Developer Mode in Discord (Settings -> Advanced) then right-click
# the channel -> Copy Channel ID.
MJ_CHANNEL_ID=

# Server (guild) ID of the channel above. Required when the MJ channel
# lives in a guild — without it the Discord interaction API returns 400
# "Unknown Channel" because the call is treated as a DM.
MJ_GUILD_ID=

# /imagine slash-command version captured via DevTools Network panel:
# fire /imagine once, find POST /api/v9/interactions, copy data.version.
# Re-capture when Midjourney ships a new slash-command version (the
# bridge surfaces this as DISCORD_400_OUTDATED).
MJ_IMAGINE_VERSION=

# /imagine slash-command application ID. The default below is usually
# stable; only re-capture (same path, copy data.id) if interactions 404.
MJ_IMAGINE_COMMAND_ID=938956540159881230

# Where finished artifacts land. Resolved relative to the cwd of the
# `cascade-mj-bridge` process at startup. Default ./generated.
MJ_OUTPUT_DIR=./generated

# HTTP port the bridge's Flask app listens on. CLI / MCP server / curl
# all hit this. Default 5000.
PORT=5000
