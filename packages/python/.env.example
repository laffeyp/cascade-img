# Copy this file to .env and fill in real values. Do NOT commit .env.

# Your Discord user token. DevTools -> Network -> any discord.com request ->
# request headers -> "Authorization". Treat like a password.
DISCORD_USER_TOKEN=

# Channel ID of your private MJ channel. Right-click channel -> Copy Channel ID.
# (Enable Developer Mode in Discord Settings -> Advanced first.)
MJ_CHANNEL_ID=

# /imagine slash command version. DevTools -> Network -> run /imagine once ->
# find POST /api/v9/interactions -> request body -> data.version
# Re-capture this whenever MJ updates the bot (you'll see 400s if it's stale).
MJ_IMAGINE_VERSION=

# /imagine slash command ID. Same capture path -> data.id. The default below is
# usually stable but verify if interactions return 404.
MJ_IMAGINE_COMMAND_ID=938956540159881230

# Where finished images go. Default ./generated relative to mj_bridge.py cwd.
MJ_OUTPUT_DIR=./generated

# HTTP port the bridge listens on (Claude/curl hits this).
PORT=5000
